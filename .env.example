# ─── AutoTools ERP — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values before running the application.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── OAuth / Authentication ──────────────────────────────────────────────────
# The App ID registered with the Manus OAuth provider
VITE_APP_ID=your_app_id_here

# Secret used to sign JWT / session cookies (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# OAuth server base URL
OAUTH_SERVER_URL=https://oauth.manus.app

# The OpenID of the initial admin / owner account
OWNER_OPEN_ID=your_owner_open_id_here

# ─── Database ────────────────────────────────────────────────────────────────
# MySQL connection string
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://erp_user:strong_password@localhost:3306/autotools_erp

# ─── Forge API (optional — for AI features) ──────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
